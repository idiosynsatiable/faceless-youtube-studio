{
  "name": "faceless-youtube-studio",
  "version": "1.0.0",
  "private": true,
  "description": "Faceless YouTube Studio — AI-assisted market intelligence, faceless video production, compliance, upload preparation, analytics feedback, and monetization planning.",
  "license": "MIT",
  "engines": {
    "node": ">=18.18.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:seed": "tsx prisma/seed.ts",
    "scan:secrets": "bash scripts/scan-secrets.sh",
    "scan:placeholders": "bash scripts/scan-placeholders.sh",
    "verify": "bash scripts/verify-studio.sh",
    "worker": "tsx src/worker/index.ts"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "redis": "4.7.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "25.6.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.19",
    "postcss": "8.4.41",
    "prisma": "5.22.0",
    "tailwindcss": "3.4.10",
    "tsx": "4.16.5",
    "typescript": "5.5.4",
    "vitest": "2.0.5"
  }
}
